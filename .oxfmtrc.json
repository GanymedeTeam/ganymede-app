{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 120,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": false,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "singleAttributePerLine": false,
  "sortImports": false,
  "sortPackageJson": false,
  "sortTailwindcss": false,
  "ignorePatterns": ["dist/**", "src-tauri/**", "node_modules/**", ".claude/**", "src/routeTree.gen.ts"]
}
